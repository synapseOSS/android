<androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content">
	<LinearLayout
		android:id="@+id/body"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:paddingLeft="8dp"
		android:paddingRight="8dp"
		android:orientation="horizontal"
		app:layout_constraintWidth_max="wrap"
		app:layout_constraintWidth_percent="0.75"
		app:layout_constraintTop_toTopOf="parent">
		<androidx.cardview.widget.CardView
			android:id="@+id/mProfileCard"
			android:layout_width="34dp"
			android:layout_height="34dp"
			android:layout_marginLeft="8dp"
			android:layout_marginTop="6dp"
			android:visibility="gone"
			app:cardElevation="0dp"
			app:cardCornerRadius="200dp">
			<ImageView
				android:id="@+id/mProfileImage"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:src="@drawable/avatar"
				android:scaleType="centerCrop"
				android:focusable="false" />
		</androidx.cardview.widget.CardView>
		<LinearLayout
			android:id="@+id/message_layout"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/messageBG"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:maxWidth="@dimen/message_bubble_max_width"
			android:layout_marginLeft="0dp"
				android:layout_marginTop="@dimen/message_vertical_spacing"
			android:layout_marginRight="0dp"
				android:layout_marginBottom="2dp"
				android:paddingLeft="12dp"
				android:paddingTop="10dp"
				android:paddingRight="12dp"
				android:paddingBottom="10dp"
				android:background="#00000000"
				android:clickable="false"
				android:focusable="false"
				android:orientation="vertical"
				android:animateLayoutChanges="true">
				<!-- Username for group chats -->
				<TextView
					android:id="@+id/senderUsername"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginBottom="4dp"
					android:textSize="12sp"
					android:textColor="?attr/colorOnSurface"
					android:textStyle="bold"
					android:visibility="gone"
					android:singleLine="true"
					android:ellipsize="end"
					android:maxWidth="200dp" />
				<!-- Forwarded indicator -->
				<LinearLayout
					android:id="@+id/forwardedIndicator"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:gravity="center_vertical"
					android:layout_marginBottom="4dp"
					android:visibility="gone">
					<ImageView
						android:layout_width="14dp"
						android:layout_height="14dp"
						android:src="@drawable/ic_forward"
						android:layout_marginEnd="4dp"
						app:tint="?attr/colorOnSurfaceVariant" />
					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Forwarded"
						android:textSize="11sp"
						android:textStyle="italic"
						android:textColor="?attr/colorOnSurfaceVariant" />
				</LinearLayout>
				<!-- Deleted message placeholder -->
				<LinearLayout
					android:id="@+id/deletedMessagePlaceholder"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:visibility="gone"
					android:padding="12dp"
					android:background="?attr/colorSurfaceVariant">
					<TextView
						android:id="@+id/deletedMessageText"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="This message was deleted"
						android:textSize="14sp"
						android:textStyle="italic"
						android:textColor="?attr/colorOnSurfaceVariant" />
				</LinearLayout>
				<!-- Message content container (hidden when deleted) -->
				<LinearLayout
					android:id="@+id/messageContentContainer"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="vertical">
				<com.google.android.material.card.MaterialCardView
					android:id="@+id/linkPreviewContainer"
					android:layout_width="250dp"
					android:layout_height="wrap_content"
					app:contentPadding="1dp"
					app:cardCornerRadius="15dp"
					app:cardElevation="0dp"
					app:strokeColor="#E0E0E0"
					app:strokeWidth="1dp">
					<LinearLayout
						android:id="@+id/linear2"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical">
						<ImageView
							android:id="@+id/linkPreviewImage"
							android:layout_width="match_parent"
							android:layout_height="120dp"
							android:src="@drawable/avatar"
							android:scaleType="centerCrop"
							android:focusable="false"
							android:visibility="gone" />
						<LinearLayout
							android:id="@+id/linear11"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:orientation="vertical">
							<TextView
								android:id="@+id/linkPreviewTitle"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="Link Title"
								android:textSize="14sp"
								android:textStyle="bold"
								android:textColor="#000000"
								android:focusable="false"
								android:maxLines="2"
								android:ellipsize="end" />
							<TextView
								android:id="@+id/linkPreviewDescription"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:text="This is a description of the webpage content..."
								android:textSize="12sp"
								android:textColor="#000000"
								android:focusable="false"
								android:maxLines="3"
								android:ellipsize="end" />
							<TextView
								android:id="@+id/linkPreviewDomain"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_marginTop="4dp"
								android:text="example.com"
								android:textSize="10sp"
								android:textColor="#666666"
								android:focusable="false" />
						</LinearLayout>
					</LinearLayout>
				</com.google.android.material.card.MaterialCardView>
				<com.google.android.material.card.MaterialCardView
					android:id="@+id/mRepliedMessageLayout"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginBottom="8dp"
					android:visibility="gone"
					app:cardElevation="0dp"
					app:cardCornerRadius="6dp">
					<LinearLayout
						android:id="@+id/linear2_replied"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:orientation="horizontal">
						<LinearLayout
							android:id="@+id/mRepliedMessageLayoutLeftBar"
							android:layout_width="4dp"
							android:layout_height="match_parent"
							android:layout_marginRight="8dp"
							android:background="#2979FF"
							android:orientation="vertical" />
						<LinearLayout
							android:id="@+id/mRepliedMessageLayoutRightBody"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:orientation="vertical">
							<TextView
								android:id="@+id/mRepliedMessageLayoutUsername"
								android:focusable="false"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:text="@string/ph_username"
								android:textSize="12sp"
								android:textColor="#445E91"
								android:singleLine="true" />
							<!-- CRITICAL FIX: Add ImageView for reply image previews -->
							<ImageView
								android:id="@+id/mRepliedMessageLayoutImage"
								android:layout_width="60dp"
								android:layout_height="60dp"
								android:layout_marginTop="4dp"
								android:layout_marginBottom="4dp"
								android:scaleType="centerCrop"
								android:background="@drawable/ph_imgbluredsqure"
								android:visibility="gone" />
							<TextView
								android:id="@+id/mRepliedMessageLayoutMessage"
								android:focusable="false"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:paddingRight="4dp"
								android:text="@string/ph_replied_message"
								android:textSize="16sp"
								android:autoLink="all"
								android:maxLines="3"
								android:ellipsize="end"
								android:textColorLink="#FF0000" />
						</LinearLayout>
					</LinearLayout>
				</com.google.android.material.card.MaterialCardView>
				<TextView
					android:id="@+id/message_text"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingTop="6dp"
					android:text="The rest of the message containing the link."
					android:textSize="16sp"
					android:focusable="false"
					android:autoLink="all"
					android:textColorLink="#FF0000" />
				</LinearLayout>
				<!-- End of messageContentContainer -->
				<!-- Metadata moved inside bubble -->
				<LinearLayout
					android:id="@+id/my_message_info"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:layout_marginRight="8dp"
					android:gravity="right|center_vertical"
					android:orientation="horizontal"
					android:layout_gravity="end">
					<TextView
						android:id="@+id/pendingIndicator"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Pending"
						android:textSize="10sp"
						android:textStyle="italic"
						android:textColor="?attr/colorSecondary"
						android:layout_marginRight="4dp"
						android:visibility="gone" />
					<TextView
						android:id="@+id/editedIndicator"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="(edited)"
						android:textSize="10sp"
						android:textStyle="italic"
						android:textColor="?attr/colorOnSurfaceVariant"
						android:layout_marginRight="4dp"
						android:visibility="gone"
						android:clickable="true"
						android:focusable="true" />
					<TextView
						android:id="@+id/date"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginRight="4dp"
						android:text="00:00"
						android:textSize="11sp"
						android:textColor="#000000"
						android:focusable="false" />
					<ImageView
						android:id="@+id/message_state"
						android:layout_width="12dp"
						android:layout_height="12dp"
						android:src="@drawable/ic_check_black"
						android:scaleType="centerInside"
						android:focusable="false" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
