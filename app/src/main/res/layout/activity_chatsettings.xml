<androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:id="@+id/_main"
	android:background="?attr/colorSurface">

	<androidx.constraintlayout.widget.ConstraintLayout
		android:id="@+id/top"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:paddingLeft="8dp"
		android:paddingTop="4dp"
		android:paddingRight="8dp"
		android:paddingBottom="4dp"
		android:background="@android:color/transparent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent">

		<ImageView
			android:id="@+id/mBack"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:padding="12dp"
			android:src="@drawable/ic_arrow_back_ios_new_48px"
			android:scaleType="fitCenter"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"/>

		<TextView
			android:id="@+id/mTitle"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_marginLeft="3dp"
			android:layout_marginRight="8dp"
			android:gravity="left|center_vertical"
			android:text="Settings"
			android:textSize="25sp"
			android:textColor="?attr/colorOnSurface"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toEndOf="@id/mBack"
			app:layout_constraintEnd_toStartOf="@id/spc"/>

		<ImageView
			android:id="@+id/spc"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:padding="12dp"
			android:background="@android:color/transparent"
			android:src="@drawable/default_image"
			android:scaleType="fitCenter"
			android:alpha="0.0"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"/>
	</androidx.constraintlayout.widget.ConstraintLayout>

	<ScrollView
		android:id="@+id/scrollMain"
		android:layout_width="0dp"
		android:layout_height="0dp"
		android:scrollbars="none"
		app:layout_constraintTop_toBottomOf="@id/top"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent">
		<LinearLayout
			android:id="@+id/scrollBody"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:paddingLeft="10dp"
			android:paddingTop="15dp"
			android:paddingBottom="15dp"
			android:background="@android:color/transparent"
			android:orientation="vertical">
			<TextView
				android:id="@+id/application_stage_title"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginLeft="8dp"
				android:layout_marginTop="15dp"
				android:layout_marginBottom="8dp"
				android:text="Chat"
				android:textSize="14sp"
				android:textColor="?attr/colorOnSurfaceVariant" />
			<androidx.constraintlayout.widget.ConstraintLayout
				android:id="@+id/application_stage"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="@android:color/transparent">

				<ImageView
					android:id="@+id/imageview31"
					android:layout_width="25dp"
					android:layout_height="25dp"
					android:layout_marginLeft="10dp"
					android:layout_marginRight="8dp"
					android:src="@drawable/ic_text_fields_48px"
					android:scaleType="fitCenter"
					app:layout_constraintTop_toTopOf="parent"
					app:layout_constraintStart_toStartOf="parent"/>

				<TextView
					android:id="@+id/textview57"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="8dp"
					android:text="Message text size"
					android:textSize="18sp"
					android:textColor="?attr/colorOnSurface"
					app:layout_constraintTop_toTopOf="@id/imageview31"
					app:layout_constraintStart_toEndOf="@id/imageview31"/>

				<com.google.android.material.slider.Slider
					android:id="@+id/seekbar6"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="10dp"
					android:padding="8dp"
					android:stepSize="1"
					android:value="12"
					android:valueFrom="16"
					android:valueTo="30"
					app:thumbColor="?attr/colorOnSurface"
					app:thumbElevation="2dp"
					app:thumbRadius="16dp"
					app:trackHeight="16dp"
					app:layout_constraintTop_toBottomOf="@id/textview57"
					app:layout_constraintStart_toStartOf="@id/textview57"
					app:layout_constraintEnd_toEndOf="parent"/>

				<com.synapse.social.studioasinc.CenterCropLinearLayoutNoEffect
					android:id="@+id/preview_font_size_layout"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:paddingTop="20dp"
					android:paddingBottom="20dp"
					android:background="@drawable/default_pattern"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical"
					app:layout_constraintTop_toBottomOf="@id/seekbar6"
					app:layout_constraintStart_toStartOf="@id/seekbar6"
					app:layout_constraintEnd_toEndOf="parent">
					<!-- Contents of this layout are complex and are kept as LinearLayouts for now -->
					<LinearLayout
						android:id="@+id/user2_preview"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingRight="8dp"
						android:background="@android:color/transparent"
						android:orientation="horizontal"
						android:animateLayoutChanges="true">
						<androidx.cardview.widget.CardView
							android:id="@+id/mProfileCard"
							android:layout_width="34dp"
							android:layout_height="34dp"
							android:layout_marginLeft="8dp"
							android:layout_marginTop="6dp"
							app:cardElevation="0dp">
							<ImageView
								android:id="@+id/mProfileImage"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:src="@drawable/avatar"
								android:scaleType="centerCrop" />
						</androidx.cardview.widget.CardView>
						<LinearLayout
							android:id="@+id/message_layout"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginLeft="8dp"
							android:orientation="vertical">
							<LinearLayout
								android:id="@+id/menuView_d"
								android:layout_width="match_parent"
								android:layout_height="0dp"
								android:padding="8dp"
								android:orientation="horizontal" />
							<LinearLayout
								android:id="@+id/messageBG"
								android:layout_width="wrap_content"
								android:layout_height="match_parent"
								android:layout_marginTop="2dp"
								android:layout_marginRight="16dp"
								android:layout_marginBottom="2dp"
								android:paddingLeft="12dp"
								android:paddingTop="10dp"
								android:paddingRight="12dp"
								android:paddingBottom="10dp"
								android:background="?attr/colorSurfaceContainerHighest"
								android:orientation="vertical">
								<LinearLayout
									android:id="@+id/mRepliedMessageLayout"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginBottom="8dp"
									android:orientation="horizontal">
									<LinearLayout
										android:id="@+id/mRepliedMessageLayoutLeftBar"
										android:layout_width="4dp"
										android:layout_height="match_parent"
										android:layout_marginRight="8dp"
										android:padding="8dp"
										android:background="?attr/colorPrimary"
										android:orientation="vertical" />
									<LinearLayout
										android:id="@+id/mRepliedMessageLayoutRightBody"
										android:layout_width="match_parent"
										android:layout_height="wrap_content"
										android:orientation="vertical">
										<TextView
											android:id="@+id/mRepliedMessageLayoutUsername"
											android:layout_width="wrap_content"
											android:layout_height="wrap_content"
											android:text="Nihad Jim"
											android:textSize="12sp"
											android:textColor="?attr/colorPrimary"
											android:singleLine="true" />
										<TextView
											android:id="@+id/mRepliedMessageLayoutMessage"
											android:layout_width="wrap_content"
											android:layout_height="wrap_content"
											android:text="Will you come tomorrow\?"
											android:textSize="16sp"
											android:textColor="?attr/colorOnSurface"
											android:singleLine="true"
											android:autoLink="all" />
									</LinearLayout>
								</LinearLayout>
								<TextView
									android:id="@+id/message_text"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="Yes ðŸ˜Ž"
									android:textSize="16sp"
									android:textColor="?attr/colorOnSurface"
									android:autoLink="all" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/my_message_info"
								android:layout_width="wrap_content"
								android:layout_height="16dp"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="8dp"
								android:layout_marginBottom="2dp"
								android:gravity="right|center_vertical"
								android:orientation="horizontal"
								android:layout_gravity="right">
								<TextView
									android:id="@+id/date"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginLeft="4dp"
									android:layout_marginRight="4dp"
									android:text="3:02 pm"
									android:textColor="?attr/colorOnSurface"
									tools:replace="android:textSize"
									android:textSize="10dp" />
							</LinearLayout>
						</LinearLayout>
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear72"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingRight="8dp"
						android:background="@android:color/transparent"
						android:gravity="right"
						android:orientation="horizontal"
						android:animateLayoutChanges="true">
						<LinearLayout
							android:id="@+id/linear73"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginTop="15dp"
							android:orientation="vertical">
							<LinearLayout
								android:id="@+id/linear74"
								android:layout_width="match_parent"
								android:layout_height="0dp"
								android:padding="8dp"
								android:orientation="horizontal" />
							<LinearLayout
								android:id="@+id/messageBG1"
								android:layout_width="wrap_content"
								android:layout_height="match_parent"
								android:layout_marginTop="2dp"
								android:layout_marginBottom="2dp"
								android:paddingLeft="12dp"
								android:paddingTop="10dp"
								android:paddingRight="12dp"
								android:paddingBottom="10dp"
								android:background="?attr/colorPrimary"
								android:orientation="vertical">
								<TextView
									android:id="@+id/txt_msg1"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="Feeling excited!"
									android:textSize="16sp"
									android:textColor="?attr/colorOnPrimary"
									android:autoLink="all" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/linear76"
								android:layout_width="wrap_content"
								android:layout_height="16dp"
								android:layout_marginLeft="8dp"
								android:layout_marginRight="8dp"
								android:layout_marginBottom="2dp"
								android:gravity="right|center_vertical"
								android:orientation="horizontal"
								android:layout_gravity="right">
								<TextView
									android:id="@+id/textview66"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginLeft="4dp"
									android:layout_marginRight="4dp"
									android:text="3:05 pm"
									android:textColor="?attr/colorOnSurface"
									tools:replace="android:textSize"
									android:textSize="10dp" />
								<ImageView
									android:id="@+id/message_state"
									android:layout_width="14dp"
									android:layout_height="14dp"
									android:layout_marginRight="4dp"
									android:src="@drawable/icon_done_all_round"
									android:scaleType="centerInside" />
							</LinearLayout>
						</LinearLayout>
					</LinearLayout>
				</com.synapse.social.studioasinc.CenterCropLinearLayoutNoEffect>

				<TextView
					android:id="@+id/textview58"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginTop="5dp"
					android:padding="4dp"
					android:text="Adjusting this font size doesn't effects the whole app."
					android:textSize="12sp"
					android:textColor="?attr/colorOnSurfaceVariant"
					app:layout_constraintTop_toBottomOf="@id/preview_font_size_layout"
					app:layout_constraintStart_toStartOf="@id/preview_font_size_layout"
					app:layout_constraintEnd_toEndOf="@id/preview_font_size_layout"/>

				<ImageView
					android:id="@+id/imageview14"
					android:layout_width="25dp"
					android:layout_height="25dp"
					android:layout_marginLeft="10dp"
					android:layout_marginRight="12dp"
					android:src="@drawable/ic_photo_library_48px"
					android:scaleType="fitCenter"
					app:layout_constraintTop_toBottomOf="@id/textview58"
					app:layout_constraintStart_toStartOf="parent"/>

				<TextView
					android:id="@+id/textview18"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Background wallpapers"
					android:textSize="18sp"
					android:textColor="?attr/colorOnSurface"
					app:layout_constraintTop_toTopOf="@id/imageview14"
					app:layout_constraintStart_toEndOf="@id/imageview14"
					android:layout_marginLeft="8dp"/>

				<TextView
					android:id="@+id/textview19"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="5dp"
					android:text="Default"
					android:textSize="14sp"
					android:textColor="?attr/colorOnSurfaceVariant"
					app:layout_constraintTop_toBottomOf="@id/textview18"
					app:layout_constraintStart_toStartOf="@id/textview18"/>

				<ImageView
					android:id="@+id/imageview32"
					android:layout_width="25dp"
					android:layout_height="20dp"
					android:layout_marginRight="20dp"
					android:src="@drawable/ic_arrow_back_ios_new_48px"
					android:scaleType="fitCenter"
					android:rotation="180"
					app:layout_constraintTop_toTopOf="@id/imageview14"
					app:layout_constraintBottom_toBottomOf="@id/imageview14"
					app:layout_constraintEnd_toEndOf="parent"/>

				<ImageView
					android:id="@+id/imageview15"
					android:layout_width="25dp"
					android:layout_height="25dp"
					android:layout_marginLeft="10dp"
					android:layout_marginTop="15dp"
					android:layout_marginRight="12dp"
					android:src="@drawable/ic_rounded_corner"
					android:scaleType="fitCenter"
					app:layout_constraintTop_toBottomOf="@id/imageview14"
					app:layout_constraintStart_toStartOf="parent"/>

				<TextView
					android:id="@+id/textview20"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Message corner round"
					android:textSize="18sp"
					android:textColor="?attr/colorOnSurface"
					app:layout_constraintTop_toTopOf="@id/imageview15"
					app:layout_constraintStart_toEndOf="@id/imageview15"
					android:layout_marginLeft="8dp"/>

				<com.google.android.material.slider.Slider
					android:id="@+id/round_seekbar"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:layout_marginBottom="5dp"
					android:padding="8dp"
					android:stepSize="1"
					android:value="16"
					android:valueFrom="5"
					android:valueTo="45"
					app:thumbColor="?attr/colorOnSurface"
					app:thumbElevation="2dp"
					app:thumbRadius="16dp"
					app:trackHeight="16dp"
					app:layout_constraintTop_toBottomOf="@id/textview20"
					app:layout_constraintStart_toStartOf="@id/textview20"
					app:layout_constraintEnd_toEndOf="parent"/>

				<TextView
					android:id="@+id/textview21"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:padding="3dp"
					android:text="This doesn't affect other UI corners' radius"
					android:textSize="12sp"
					android:textColor="?attr/colorOnSurfaceVariant"
					app:layout_constraintTop_toBottomOf="@id/round_seekbar"
					app:layout_constraintStart_toStartOf="@id/round_seekbar"
					app:layout_constraintEnd_toEndOf="@id/round_seekbar"/>

				<ImageView
					android:id="@+id/imageview13"
					android:layout_width="25dp"
					android:layout_height="25dp"
					android:layout_marginLeft="10dp"
					android:layout_marginTop="8dp"
					android:layout_marginRight="12dp"
					android:src="@drawable/ic_category"
					android:scaleType="fitCenter"
					app:layout_constraintTop_toBottomOf="@id/textview21"
					app:layout_constraintStart_toStartOf="parent"/>

				<TextView
					android:id="@+id/textview15"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Theme store"
					android:textSize="18sp"
					android:textColor="?attr/colorOnSurface"
					app:layout_constraintTop_toTopOf="@id/imageview13"
					app:layout_constraintStart_toEndOf="@id/imageview13"
					android:layout_marginLeft="8dp"/>

				<TextView
					android:id="@+id/textview16"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginTop="5dp"
					android:text="Theme changes the whole apps overall interface, colours, fonts, and images as well"
					android:textSize="14sp"
					android:textColor="?attr/colorOnSurfaceVariant"
					app:layout_constraintTop_toBottomOf="@id/textview15"
					app:layout_constraintStart_toStartOf="@id/textview15"
					app:layout_constraintEnd_toEndOf="parent"/>

			</androidx.constraintlayout.widget.ConstraintLayout>
			<TextView
				android:id="@+id/textview67"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="20dp"
				android:layout_marginBottom="8dp"
				android:text="App icon"
				android:textSize="14sp"
				android:textColor="?attr/colorOnSurfaceVariant" />
			<androidx.recyclerview.widget.RecyclerView
				android:id="@+id/recyclerview2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp" />
			<TextView
				android:id="@+id/textview68"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="20dp"
				android:layout_marginBottom="8dp"
				android:text="Chat list swipe gesture"
				android:textSize="14sp"
				android:textColor="?attr/colorOnSurfaceVariant" />
			<TextView
				android:id="@+id/textview22"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="20dp"
				android:layout_marginBottom="8dp"
				android:text="Media and sound"
				android:textSize="14sp"
				android:textColor="?attr/colorOnSurfaceVariant" />
			<androidx.constraintlayout.widget.ConstraintLayout
				android:id="@+id/account_stack_3"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="@android:color/transparent">

				<ImageView
					android:id="@+id/imageview16"
					android:layout_width="25dp"
					android:layout_height="25dp"
					android:layout_marginLeft="10dp"
					android:layout_marginRight="12dp"
					android:src="@drawable/ic_touch"
					android:scaleType="fitCenter"
					app:layout_constraintTop_toTopOf="parent"
					app:layout_constraintStart_toStartOf="parent"/>

				<TextView
					android:id="@+id/textview24"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="Tap to show next media"
					android:textSize="18sp"
					android:textColor="?attr/colorOnSurface"
					app:layout_constraintTop_toTopOf="@id/imageview16"
					app:layout_constraintStart_toEndOf="@id/imageview16"
					app:layout_constraintEnd_toStartOf="@id/switch1"
					android:layout_marginLeft="8dp"/>

				<TextView
					android:id="@+id/textview25"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginTop="5dp"
					android:text="Tap near the edge of the screen while viewing media to navigate"
